{
  "name": "dsers-shopify-bot",
  "version": "1.0.0",
  "description": "Automated Shopify importer using DSers and various sources",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bullmq": "^4.15.0",
    "csv-parse": "^5.5.2",
    "date-fns": "^2.30.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.2",
    "fastify-raw-body": "^5.0.0",
    "googleapis": "^134.0.0",
    "ioredis": "^5.3.2",
    "nanoid": "^5.0.7",
    "node-cron": "^3.0.3",
    "pino": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/csv-parse": "^1.1.9",
    "@types/node-cron": "^3.0.11",
    "@types/node": "^20.12.7",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
